{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git", "**/*.log"]
  },
  "hosting": {
    "public": "public",
    "redirects": [
      {
        "source": "/",
        "destination": "/passport",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/impactbingo/facilitator",
        "destination": "/impactbingo/facilitator/index.html"
      },
      {
        "source": "/impactbingo/facilitator/**",
        "destination": "/impactbingo/facilitator/index.html"
      },
      {
        "source": "/impactbingo/dashboard",
        "destination": "/impactbingo/dashboard/index.html"
      },
      {
        "source": "/impactbingo/dashboard/**",
        "destination": "/impactbingo/dashboard/index.html"
      },
      {
        "source": "/impactbingo",
        "destination": "/impactbingo/index.html"
      },
      {
        "source": "/impactbingo/**",
        "destination": "/impactbingo/index.html"
      },
      {
        "source": "/passport/facilitator",
        "destination": "/passport/facilitator/index.html"
      },
      {
        "source": "/passport/facilitator/**",
        "destination": "/passport/facilitator/index.html"
      },
      {
        "source": "/passport",
        "destination": "/passport/index.html"
      },
      {
        "source": "/passport/**",
        "destination": "/passport/index.html"
      }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "hosting": { "port": 5002 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
